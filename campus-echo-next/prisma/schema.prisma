// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id         String    @id // "ETHZ", "UZH"
  name       String
  domains    String[] // ["ethz.ch", "student.ethz.ch"]
  created_at DateTime  @default(now())

  users    User[]
  posts    Post[]
  listings Listing[]
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password_hash    String
  display_name     String?
  handle           String    @unique
  anon_id          String    @unique
  role             String    @default("user") // "user" | "admin" | "moderator"
  school_id        String?
  school_email     String?
  school_verified  Boolean   @default(false)
  verified_at      DateTime?
  age_verified     Boolean   @default(false)
  unlock_at        DateTime? // future unlock date for under‑18 users
  mood             String?   @default("chill")
  avatar_base      String?
  avatar_accessory String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  school         School?             @relation(fields: [school_id], references: [id])
  posts          Post[]
  comments       Comment[]
  votes          Vote[]
  reports        Report[]            @relation("reporter")
  listings       Listing[]
  verifications  EmailVerification[]
  blockedBy      Block[]             @relation("blocked")
  blocking       Block[]             @relation("blocker")
  tokenDenylists TokenDenylist[]
  listingThreadsAsBuyer  ListingThread[] @relation("buyer")
  listingThreadsAsSeller ListingThread[] @relation("seller")
  listingMessages        ListingMessage[]
  pollVotes      PollVote[]
}

model EmailVerification {
  id           String   @id @default(cuid())
  user_id      String
  school_email String
  school       String
  code_hash    String
  verified     Boolean  @default(false)
  expires_at   DateTime
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model TokenDenylist {
  id         String   @id @default(cuid())
  token_hash String   @unique
  user_id    String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Post {
  id              String    @id @default(cuid())
  school_id       String
  author_id       String
  author_anon_id  String
  author_mood     String?
  content         String
  category        String    @default("general")
  post_type       String    @default("text") // "text"|"poll"|"repost"|"quote"
  upvotes         Int       @default(0)
  downvotes       Int       @default(0)
  score           Float     @default(0)
  comment_count   Int       @default(0)
  repost_count    Int       @default(0)
  quote_count     Int       @default(0)
  reported_count  Int       @default(0)
  parent_post_id  String?
  root_post_id    String?
  event_date      DateTime?
  event_location  String?
  event_type      String?
  event_interests String[]
  gif_url         String?
  created_at      DateTime  @default(now())
  deleted_at      DateTime?

  school      School       @relation(fields: [school_id], references: [id])
  author      User         @relation(fields: [author_id], references: [id])
  comments    Comment[]
  votes       Vote[]
  pollOptions PollOption[]
  reports     Report[]
}

model PollOption {
  id          String @id @default(cuid())
  post_id     String
  text        String
  votes_count Int    @default(0)
  order_index Int

  post      Post       @relation(fields: [post_id], references: [id], onDelete: Cascade)
  pollVotes PollVote[]
}

model PollVote {
  id         String   @id @default(cuid())
  option_id  String
  user_id    String
  created_at DateTime @default(now())

  option PollOption @relation(fields: [option_id], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([option_id, user_id])
}

model Comment {
  id             String    @id @default(cuid())
  post_id        String
  author_id      String
  author_anon_id String
  author_mood    String?
  content        String
  upvotes        Int       @default(0)
  downvotes      Int       @default(0)
  reported_count Int       @default(0)
  created_at     DateTime  @default(now())
  deleted_at     DateTime?

  post    Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)
  author  User     @relation(fields: [author_id], references: [id])
  votes   Vote[]
  reports Report[]
}

model Vote {
  id          String   @id @default(cuid())
  user_id     String
  target_type String // "post" | "comment"
  target_id   String
  vote_value  Int // 1 | -1
  created_at  DateTime @default(now())

  user    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [target_id], references: [id], map: "vote_post_fk")
  comment Comment? @relation(fields: [target_id], references: [id], map: "vote_comment_fk")

  @@unique([user_id, target_id])
}

model Listing {
  id                  String    @id @default(cuid())
  school_id           String
  seller_id           String
  seller_anon_id      String
  title               String
  description         String?
  price               Float     @default(0)
  is_free             Boolean   @default(false)
  category            String // "electronics"|"furniture"|"clothing"|"books"|"other"
  condition           String // "new"|"like_new"|"good"|"fair"|"poor"
  pickup_location_tag String?
  status              String    @default("active") // "active"|"reserved"|"sold"|"archived"
  reported_count      Int       @default(0)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleted_at          DateTime?

  school   School          @relation(fields: [school_id], references: [id])
  seller   User            @relation(fields: [seller_id], references: [id])
  images   ListingImage[]
  threads  ListingThread[]
  reports  Report[]
}

model ListingImage {
  id          String @id @default(cuid())
  listing_id  String
  url         String
  order_index Int

  listing Listing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
}

model ListingThread {
  id         String   @id @default(cuid())
  listing_id String
  buyer_id   String
  seller_id  String
  status     String   @default("open") // "open"|"closed"
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  listing  Listing          @relation(fields: [listing_id], references: [id])
  buyer    User             @relation("buyer", fields: [buyer_id], references: [id])
  seller   User             @relation("seller", fields: [seller_id], references: [id])
  messages ListingMessage[]
}

model ListingMessage {
  id          String   @id @default(cuid())
  thread_id   String
  sender_id   String
  sender_role String // "buyer" | "seller"
  content     String
  read        Boolean  @default(false)
  created_at  DateTime @default(now())

  thread ListingThread @relation(fields: [thread_id], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [sender_id], references: [id])
}

model Report {
  id          String   @id @default(cuid())
  reporter_id String
  target_type String // "post" | "comment" | "listing"
  target_id   String
  reason      String
  status      String   @default("pending") // "pending"|"resolved"|"dismissed"
  created_at  DateTime @default(now())

  reporter User     @relation("reporter", fields: [reporter_id], references: [id])
  post     Post?    @relation(fields: [target_id], references: [id], map: "report_post_fk")
  comment  Comment? @relation(fields: [target_id], references: [id], map: "report_comment_fk")
  listing  Listing? @relation(fields: [target_id], references: [id], map: "report_listing_fk")
}

model Block {
  id         String   @id @default(cuid())
  blocker_id String
  blocked_id String
  created_at DateTime @default(now())

  blocker User @relation("blocker", fields: [blocker_id], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blocked_id], references: [id], onDelete: Cascade)

  @@unique([blocker_id, blocked_id])
}
